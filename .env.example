# Ansible Sage Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# LLM Provider Configuration
# ============================================================================

# Choose provider: claude, openai, ollama, custom
LLM_PROVIDER=claude

# Claude (Anthropic)
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4-turbo-preview

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3:70b

# Custom Provider
CUSTOM_LLM_ENDPOINT=http://your-llm:8000/v1/chat/completions
CUSTOM_LLM_API_KEY=your-custom-key
CUSTOM_LLM_MODEL=your-model-name

# ============================================================================
# Ansible Automation Platform Integration
# ============================================================================

AAP_URL=https://aap.example.com
AAP_TOKEN=your-aap-token-here
AAP_VERIFY_SSL=true
AAP_ORGANIZATION=Default

# ============================================================================
# Git Repository Configuration (for publishing generated playbooks)
# ============================================================================

# Git repository for playbook storage
GIT_REPO_URL=https://github.com/your-org/ansible-playbooks.git
GIT_MAIN_BRANCH=main
GIT_REVIEW_BRANCH=review
GIT_DRAFT_BRANCH=draft
GIT_PLAYBOOKS_DIR=playbooks/generated

# Git authentication
GIT_USERNAME=ansible-sage-bot
GIT_EMAIL=ansible-sage@example.com

# Use either SSH key OR Personal Access Token (PAT), not both
# For SSH: GIT_REPO_URL should be git@github.com:your-org/repo.git
GIT_SSH_KEY_PATH=/path/to/ssh/key

# For HTTPS: Use PAT (GitHub, GitLab, etc.)
GIT_TOKEN=ghp_YourGitHubPersonalAccessToken

# Auto-publish settings
GIT_AUTO_PUBLISH=false  # If true, automatically push to Git after generation
GIT_CREATE_PR=true  # Create pull request for medium/low confidence playbooks

# ============================================================================
# Service Configuration
# ============================================================================

# Logging
SAGE_LOG_LEVEL=INFO
SAGE_LOG_FORMAT=json
SAGE_LOG_LLM_PROMPTS=false
SAGE_LOG_LLM_RESPONSES=false

# API Server
SAGE_API_HOST=0.0.0.0
SAGE_API_PORT=8000
SAGE_API_WORKERS=4
SAGE_CORS_ORIGINS=*

# Generation Settings
SAGE_ENABLE_MOLECULE_TESTING=true
SAGE_AUTO_EXECUTE_THRESHOLD=0.8
SAGE_MAX_GENERATION_RETRIES=3
SAGE_GENERATION_TIMEOUT=60

# Validation
SAGE_ANSIBLE_LINT_AUTO_FIX=true
SAGE_STRICT_YAML_VALIDATION=true

# ============================================================================
# Database Configuration
# ============================================================================

DATABASE_URL=postgresql://sage:changeme@postgres:5432/ansible_sage
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ============================================================================
# Redis Configuration
# ============================================================================

REDIS_URL=redis://redis:6379/0
REDIS_MAX_CONNECTIONS=50

# Cache TTL (seconds)
CACHE_PLAYBOOK_TTL=3600
CACHE_EVENT_DEDUP_TTL=300

# ============================================================================
# Event-Driven Ansible (EDA) Integration
# ============================================================================

EDA_ENABLED=false
EDA_WEBHOOK_SECRET=your-webhook-secret

# ============================================================================
# Monitoring & Observability
# ============================================================================

# Prometheus metrics
METRICS_ENABLED=true
METRICS_PORT=9090

# OpenTelemetry
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# ============================================================================
# Security
# ============================================================================

# API Authentication (optional)
API_KEY_ENABLED=false
API_KEY=your-secret-api-key

# JWT Authentication (optional)
JWT_SECRET_KEY=your-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================================================
# Feature Flags
# ============================================================================

FEATURE_AAP_CATALOG_SEARCH=true
FEATURE_MOLECULE_TESTING=true
FEATURE_MULTI_MODEL_SUPPORT=true
FEATURE_HITL_APPROVAL=true

# ============================================================================
# Development Settings
# ============================================================================

# Only set to true in development!
DEBUG=false
RELOAD=false

# Test mode (uses mock LLM)
TEST_MODE=false
