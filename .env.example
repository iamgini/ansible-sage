# Ansible Maya Configuration
# Copy this file to .env and configure your LLM provider

# ============================================================================
# LLM Provider Configuration (Choose One)
# ============================================================================

# Available providers: claude, openai, custom
LLM_PROVIDER=claude

# ----------------------------------------------------------------------------
# Option 1: Claude (Anthropic) - Recommended
# ----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# ----------------------------------------------------------------------------
# Option 2: OpenAI (GPT-4, GPT-3.5, etc.)
# ----------------------------------------------------------------------------
# OPENAI_API_KEY=sk-your-openai-key-here

# ----------------------------------------------------------------------------
# Option 3: Custom OpenAI-Compatible Endpoint
# ----------------------------------------------------------------------------
# Examples: LiteLLM, vLLM, Ollama, LocalAI, Azure OpenAI, etc.
# CUSTOM_LLM_ENDPOINT=https://your-llm-endpoint.com/v1
# CUSTOM_LLM_MODEL=your-model-name
# CUSTOM_LLM_API_KEY=your-api-key

# ============================================================================
# That's it! No database, cache, or other services needed.
# Ansible Maya is a stateless API - just LLM + validation.
# ============================================================================
