build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
*.manifest
*.spec
pip-log.txt
pip-delete-this-directory.txt

# Virtual environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/
.python-version

# PyCharm
.idea/
*.iml
*.iws
.idea_modules/

# VSCode
.vscode/
*.code-workspace
.history/

# Jupyter Notebook
.ipynb_checkpoints
*.ipynb

# Testing
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/
.pytest_cache/
nosetests.xml
test-results/

# MyPy
.mypy_cache/
.dmypy.json
dmypy.json

# Ruff
.ruff_cache/

# Docker
*.log
docker-compose.override.yml

# Environment variables
.env
.env.local
.env.*.local
*.env

# Secrets (be extra careful!)
secrets/
*.key
*.pem
*.crt
*.p12
*_rsa
*_rsa.pub
ansible-vault-password.txt

# Generated files
generated/
output/
playbooks/generated/
*.generated.yml
*.generated.yaml

# Ansible
*.retry
.ansible/
ansible.log

# Database
*.db
*.sqlite
*.sqlite3
db.sqlite3

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*~

# Temporary files
tmp/
temp/
*.tmp
*.bak
*.swp
*.swo

# Documentation builds
docs/_build/
docs/.doctrees/
site/

# Package managers
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

# Molecule
molecule/*/.molecule/
